---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Página no encontrada" description="La página que buscas no existe.">
  <section class="max-w-2xl mx-auto px-4 py-24 text-center">
    <div class="text-6xl mb-6">🔒</div>
    <h1 class="text-4xl font-extrabold text-secondary mb-4">404 - Página no encontrada</h1>
    <p class="text-gray-600 text-lg mb-8">
      Parece que esta puerta no existe. Pero no te preocupes, sabemos abrir cualquier otra.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 bg-primary hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl transition-colors"
    >
      ← Volver al inicio
    </a>
  </section>
</BaseLayout>
