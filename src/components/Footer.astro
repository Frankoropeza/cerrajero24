---
const year = new Date().getFullYear();
---

<footer class="bg-secondary text-gray-400 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-white mb-4">
          <span class="text-2xl">🔑</span>
          <span class="text-accent">CERRAJERO</span>
          <span>24</span>
        </a>
        <p class="text-sm">
          Servicio profesional de cerrajería disponible las 24 horas del día,
          los 365 días del año. Respuesta rápida y garantizada.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">Servicios</h3>
        <ul class="space-y-2 text-sm">
          <li>Apertura de puertas</li>
          <li>Cambio de cerraduras</li>
          <li>Apertura de coches</li>
          <li>Cajas fuertes</li>
          <li>Duplicado de llaves</li>
          <li>Emergencias 24h</li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4">Contacto</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="tel:900123456" class="hover:text-accent transition-colors">
              📞 900 123 456
            </a>
          </li>
          <li>📧 info@cerrajero24.es</li>
          <li>📍 Servicio en toda España</li>
          <li>🕐 24 horas / 365 días</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-700 mt-8 pt-8 text-center text-sm">
      <p>&copy; {year} Cerrajero 24. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
