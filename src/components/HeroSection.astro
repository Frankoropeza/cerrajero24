---

---

<section class="relative bg-gradient-to-br from-secondary via-gray-900 to-primary text-white overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 25%, #FBBF24 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <div class="text-center">
      <!-- Badge urgencia -->
      <div class="inline-flex items-center gap-2 bg-accent/20 text-accent px-4 py-2 rounded-full text-sm font-semibold mb-6">
        <span class="relative flex h-3 w-3">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
          <span class="relative inline-flex rounded-full h-3 w-3 bg-accent"></span>
        </span>
        Servicio de emergencia 24/7
      </div>

      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-6">
        Abrimos tu puerta<br />
        <span class="text-accent">en 30 minutos</span>
      </h1>

      <p class="text-xl md:text-2xl text-gray-300 max-w-2xl mx-auto mb-8">
        Cerrajeros profesionales disponibles las 24 horas.
        Sin daños, sin esperas, con garantía.
      </p>

      <!-- Teléfono grande -->
      <div class="mb-8">
        <a
          href="tel:900123456"
          class="inline-flex items-center gap-3 bg-accent hover:bg-yellow-300 text-secondary font-extrabold text-2xl md:text-4xl px-8 py-4 md:px-12 md:py-6 rounded-2xl shadow-2xl shadow-accent/25 transition-all hover:scale-105"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 md:h-10 md:w-10" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          900 123 456
        </a>
      </div>

      <p class="text-gray-400 text-sm">
        Llamada gratuita · Presupuesto sin compromiso · Toda España
      </p>

      <!-- Trust badges -->
      <div class="flex flex-wrap justify-center gap-6 mt-10 text-sm text-gray-300">
        <div class="flex items-center gap-2">
          <span class="text-accent text-lg">✓</span> Respuesta inmediata
        </div>
        <div class="flex items-center gap-2">
          <span class="text-accent text-lg">✓</span> Sin daños en tu puerta
        </div>
        <div class="flex items-center gap-2">
          <span class="text-accent text-lg">✓</span> Precio cerrado antes de empezar
        </div>
      </div>
    </div>
  </div>
</section>
