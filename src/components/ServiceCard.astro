---
interface Props {
  title: string;
  description: string;
  icon: string;
  urgent?: boolean;
}

const { title, description, icon, urgent = false } = Astro.props;
---

<div
  class:list={[
    "relative bg-white rounded-2xl p-6 shadow-md hover:shadow-xl transition-all hover:-translate-y-1 border",
    urgent ? "border-accent" : "border-gray-100",
  ]}
>
  {
    urgent && (
      <span class="absolute -top-3 right-4 bg-accent text-secondary text-xs font-bold px-3 py-1 rounded-full">
        URGENTE 24H
      </span>
    )
  }
  <div class="text-4xl mb-4">{icon}</div>
  <h3 class="text-lg font-bold text-secondary mb-2">{title}</h3>
  <p class="text-gray-600 text-sm">{description}</p>
</div>
